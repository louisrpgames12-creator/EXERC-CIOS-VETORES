#include <stdio.h>

int main() {
    int array[5] = {0}, i, j = 4, aux; 
    
    printf("ME INFORME 5 VALORES: ");
    for(i = 0; i < 5; i++) {
        scanf("%d", &array[i]);
    }
    
    printf("ARRAY 1: ");
    for(i = 0; i < 5; i++) {
        printf("%d ", array[i]);
    }
    
    for(i = 0; i < 2; i++) {
        aux = array[i];      
        array[i] = array[j];  
        array[j] = aux;       
        
        j--; 
    }
    
    printf("\nARRAY 2: ");
    for(i = 0; i < 5; i++) {
        printf("%d ", array[i]);
    }

    return 0;
}
